{
  "name": "@lania-pro-components/components",
  "version": "1.0.0",
  "description": "基于 Arco Design 的 Schema 驱动企业级组件库",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./ActionButton": {
      "import": "./dist/ActionButton/index.mjs",
      "require": "./dist/ActionButton/index.cjs",
      "types": "./dist/ActionButton/index.d.ts"
    },
    "./ProDialog": {
      "import": "./dist/ProDialog/index.mjs",
      "require": "./dist/ProDialog/index.cjs",
      "types": "./dist/ProDialog/index.d.ts"
    },
    "./ProForm": {
      "import": "./dist/ProForm/index.mjs",
      "require": "./dist/ProForm/index.cjs",
      "types": "./dist/ProForm/index.d.ts"
    },
    "./ProTable": {
      "import": "./dist/ProTable/index.mjs",
      "require": "./dist/ProTable/index.cjs",
      "types": "./dist/ProTable/index.d.ts"
    },
    "./ProSelect": {
      "import": "./dist/ProSelect/index.mjs",
      "require": "./dist/ProSelect/index.cjs",
      "types": "./dist/ProSelect/index.d.ts"
    },
    "./ProUpload": {
      "import": "./dist/ProUpload/index.mjs",
      "require": "./dist/ProUpload/index.cjs",
      "types": "./dist/ProUpload/index.d.ts"
    }
  },
  "scripts": {
    "build": "rollup -c ../../rollup.config.js",
    "dev": "rollup -c ../../rollup.config.js -w",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "arco-design",
    "pro-components",
    "schema-driven",
    "form",
    "table",
    "dialog"
  ],
  "author": "",
  "license": "ISC",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@lania-pro-components/utils": "workspace:*",
    "@lania-pro-components/shared": "workspace:*"
  },
  "peerDependencies": {
    "@arco-design/web-react": "^2.66.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  }
}