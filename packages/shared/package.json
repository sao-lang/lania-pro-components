{
  "name": "@lania-pro-components/shared",
  "version": "1.0.0",
  "description": "React 抽象底座包 - 跨组件复用的 Hooks、组件、工厂函数、类型定义（React 感知，Arco 解耦）",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./hooks": {
      "import": "./dist/hooks.esm.js",
      "require": "./dist/hooks.cjs",
      "types": "./dist/hooks.d.ts"
    },
    "./PerformanceMonitor": {
      "import": "./dist/PerformanceMonitor.esm.js",
      "require": "./dist/PerformanceMonitor.cjs",
      "types": "./dist/PerformanceMonitor.d.ts"
    }
  },
  "scripts": {
    "build": "rollup -c ../../rollup.config.js",
    "dev": "rollup -c ../../rollup.config.js -w",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "lania-pro",
    "shared",
    "hooks",
    "react",
    "components"
  ],
  "author": "",
  "license": "ISC",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@lania-pro-components/utils": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  }
}
