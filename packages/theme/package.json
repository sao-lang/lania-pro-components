{
  "name": "@lania-pro-components/theme",
  "version": "1.0.0",
  "description": "主题包 - 提供 light 和 dark 两种主题",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./light.css": "./dist/light.css",
    "./dark.css": "./dist/dark.css"
  },
  "scripts": {
    "build": "rollup -c ../../rollup.config.js && pnpm copy:css",
    "dev": "rollup -c ../../rollup.config.js -w",
    "typecheck": "tsc --noEmit",
    "copy:css": "copy \"src\\light.css\" \"dist\\light.css\" && copy \"src\\dark.css\" \"dist\\dark.css\""
  },
  "keywords": [
    "theme",
    "light",
    "dark",
    "design-tokens"
  ],
  "author": "",
  "license": "ISC",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  }
}
