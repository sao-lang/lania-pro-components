{
  "name": "@lania-pro-components/components",
  "version": "1.0.0",
  "description": "基于 Arco Design 的 Schema 驱动企业级组件库",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @lania-pro-components/components build",
    "dev": "pnpm --filter @lania-pro-components/components dev",
    "typecheck": "pnpm --filter @lania-pro-components/components typecheck",
    "lint": "eslint @lania-pro-components/components --ext .ts,.tsx",
    "lint:fix": "eslint @lania-pro-components/components --ext .ts,.tsx --fix",
    "format": "prettier --write @lania-pro-components/components",
    "format:check": "prettier --check @lania-pro-components/components",
    "clean": "rm -rf @lania-pro-components/components/dist",
    "install:all": "pnpm install",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "arco-design",
    "pro-components",
    "schema-driven"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.26.1",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@arco-design/web-react": "^2.66.15",
    "dayjs": "^1.11.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/plugin-syntax-typescript": "^7.29.7",
    "@babel/preset-react": "^7.24.7",
    "@babel/preset-typescript": "^7.29.7",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.5.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.2.0",
    "@typescript-eslint/parser": "^8.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/ui": "^4.1.9",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.3.3",
    "rollup": "^4.21.2",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.9"
  }
}
