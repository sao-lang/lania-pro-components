{
  "name": "@lania-pro-components/monorepo",
  "version": "1.0.0",
  "description": "基于 Arco Design 的 Schema 驱动企业级组件库 - Monorepo",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @lania-pro/components build",
    "dev": "pnpm --filter @lania-pro/components dev",
    "typecheck": "pnpm --filter @lania-pro/components typecheck",
    "lint": "eslint packages/components --ext .ts,.tsx",
    "lint:fix": "eslint packages/components --ext .ts,.tsx --fix",
    "format": "prettier --write packages/components",
    "format:check": "prettier --check packages/components",
    "clean": "rm -rf packages/components/dist",
    "install:all": "pnpm install"
  },
  "keywords": [
    "arco-design",
    "pro-components",
    "schema-driven",
    "monorepo"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.26.1",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@arco-design/web-react": "^2.66.15",
    "dayjs": "^1.11.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-react": "^7.24.7",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^22.5.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.2.0",
    "@typescript-eslint/parser": "^8.2.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.3.3",
    "rollup": "^4.21.2",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "^6.0.3"
  }
}