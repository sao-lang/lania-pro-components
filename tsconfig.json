{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./packages/components/dist",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@lania-pro/components": ["packages/components"],
      "@lania-pro/components/*": ["packages/components/*"],
      "@lania-pro-components/components": ["packages/components"],
      "@lania-pro-components/components/*": ["packages/components/*"],
      "@lania-pro-components/utils": ["packages/utils/src"],
      "@lania-pro-components/utils/*": ["packages/utils/src/*"],
      "@lania-pro-components/shared": ["packages/shared/src"],
      "@lania-pro-components/shared/*": ["packages/shared/src/*"],
      "@lania-pro/theme": ["packages/theme"],
      "@lania-pro/theme/*": ["packages/theme/*"],
      "@lania-pro-components/theme": ["packages/theme/src"],
      "@lania-pro-components/theme/*": ["packages/theme/src/*"]
    },
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["node"]
  },
  "include": [
    "packages/components/**/*",
    "packages/theme/**/*",
    "packages/utils/**/*",
    "**/*.js",
    "**/*.cjs",
    "**/*.mjs",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": ["node_modules", "dist", "**/dist"]
}
